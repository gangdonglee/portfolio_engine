{
  "name": "XBot",
  "defaultStateName": "Idle",
  "states": [
    {
      "name": "Idle",
      "motionClipPath": "Resources/FBX/Breathing Idle.fbx",
      "loop": true,
      "speed": 1.0
    },
    {
      "name": "Walk",
      "motionClipPath": "Resources/FBX/Walking.fbx",
      "loop": true,
      "speed": 1.0
    },
    {
      "name": "Run",
      "motionClipPath": "Resources/FBX/Running.fbx",
      "loop": true,
      "speed": 1.0
    },
    {
      "name": "Jump",
      "motionClipPath": "Resources/FBX/Jump.fbx",
      "loop": false,
      "speed": 1.0
    }
  ],
  "parameters": [
    { "name": "Speed", "type": "Float",   "defaultValue": 0.0 },
    { "name": "Jump",  "type": "Trigger", "defaultValue": 0.0 }
  ],
  "transitions": [
    {
      "fromStateName": "Idle",
      "toStateName":   "Walk",
      "crossfadeDuration": 0.2,
      "hasExitTime": false,
      "exitTime": 0.0,
      "conditions": [
        { "parameterName": "Speed", "op": "Greater", "value": 0.1 }
      ]
    },
    {
      "fromStateName": "Walk",
      "toStateName":   "Run",
      "crossfadeDuration": 0.2,
      "hasExitTime": false,
      "exitTime": 0.0,
      "conditions": [
        { "parameterName": "Speed", "op": "Greater", "value": 0.5 }
      ]
    },
    {
      "fromStateName": "Run",
      "toStateName":   "Walk",
      "crossfadeDuration": 0.2,
      "hasExitTime": false,
      "exitTime": 0.0,
      "conditions": [
        { "parameterName": "Speed", "op": "Less", "value": 0.5 }
      ]
    },
    {
      "fromStateName": "Walk",
      "toStateName":   "Idle",
      "crossfadeDuration": 0.2,
      "hasExitTime": false,
      "exitTime": 0.0,
      "conditions": [
        { "parameterName": "Speed", "op": "Less", "value": 0.1 }
      ]
    },
    {
      "fromStateName": "",
      "toStateName":   "Jump",
      "crossfadeDuration": 0.1,
      "hasExitTime": false,
      "exitTime": 0.0,
      "conditions": [
        { "parameterName": "Jump", "op": "IfTrue", "value": 0.0 }
      ]
    },
    {
      "fromStateName": "Jump",
      "toStateName":   "Idle",
      "crossfadeDuration": 0.2,
      "hasExitTime": true,
      "exitTime": 1.0,
      "conditions": []
    }
  ]
}
